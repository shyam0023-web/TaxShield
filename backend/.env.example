# TaxShield Backend — Environment Variables
# Copy this file to .env and fill in your values

# ═══ LLM Keys (at least one required) ═══
GROQ_API_KEY=your-groq-api-key-here
GEMINI_API_KEY=              # Optional — currently unused

# ═══ Auth ═══
# IMPORTANT: Change this in production! Must be a strong, random string.
JWT_SECRET_KEY=change-me-to-a-random-secret

# ═══ Database ═══
DATABASE_URL=sqlite:///./taxshield.db    # Use postgresql:// for production

# ═══ CORS ═══
# Comma-separated origins, or * for wide-open dev mode
CORS_ORIGINS=http://localhost:3000

# ═══ Optional ═══
COHERE_API_KEY=              # For reranker (optional)
REDIS_URL=redis://localhost:6379
WEBHOOK_URL=                 # Slack/Teams webhook for alerts
DEBUG=true
RATE_LIMIT_PER_MINUTE=60
