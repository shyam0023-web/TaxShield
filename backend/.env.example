# ═══════════════════════════════════════════
# TaxShield Backend — Environment Variables
# Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════

# LLM Providers
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=                          # Optional — fallback LLM

# Database (Supabase PostgreSQL)
# Use the POOLER URL (port 6543), NOT direct (port 5432)
DATABASE_URL=postgresql://postgres.[project-ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres

# Redis (Upstash or local)
REDIS_URL=redis://localhost:6379

# Auth — CHANGE THIS IN PRODUCTION
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=taxshield-dev-secret-change-in-production
JWT_ACCESS_TOKEN_EXPIRE_HOURS=24

# CORS — your Vercel frontend domain
CORS_ORIGINS=http://localhost:3000

# App Mode
DEBUG=True

# Observability (optional)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
